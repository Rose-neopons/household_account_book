{
  "expo": {
    "name": "AI Pocket Guard",
    "slug": "ai-pocket-guard",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aipocketguard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    }
  }
}
